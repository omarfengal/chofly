# ─────────────────────────────────────────────────────────────────────
# CHOFLY — .gitignore Flutter
# ─────────────────────────────────────────────────────────────────────

# ── Dart / Flutter ────────────────────────────────────────────────────
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
*.dart_tool/
# pubspec.lock → NE PAS ignorer pour une app (garder pour reproductibilité CI)

# ── Android ───────────────────────────────────────────────────────────
android/.gradle/
android/captures/
# android/gradlew     ← requis en CI (fichier de projet Flutter, pas un artefact)
# android/gradlew.bat ← idem
android/local.properties
android/key.properties
android/*.jks
android/app/google-services.json  # injecté par Codemagic via GOOGLE_SERVICES_JSON

# ── iOS ────────────────────────────────────────────────────────────────
ios/.symlinks/
ios/Flutter/App.framework/
ios/Flutter/Flutter.framework/
ios/Flutter/Flutter.podspec
ios/Flutter/Generated.xcconfig
ios/Flutter/ephemeral/
ios/Pods/
ios/Runner.xcworkspace/
*.mode1v3
*.mode2v3
*.moved-aside
*.pbxuser
!default.pbxuser
*.perspectivev3
!default.perspectivev3
xcuserdata/
*.xccheckout
*.xcscmblueprint
GoogleService-Info.plist

# ── Firebase ──────────────────────────────────────────────────────────
# lib/firebase_options.dart ← NE PAS ignorer : placeholder sans vraies clés, importé par main.dart
google-services.json

# ── CI/CD ─────────────────────────────────────────────────────────────
*.keystore
*.p12
*.p8
*.mobileprovision
codemagic-private-key.pem

# ── Éditeurs / IDE ────────────────────────────────────────────────────
.idea/
.vscode/
*.iml
*.ipr
*.iws
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ── Tests / Coverage ──────────────────────────────────────────────────
coverage/
*.lcov

# ── Logs & temporaires ────────────────────────────────────────────────
*.log
*.tmp
*.bak
*.orig
npm-debug.log*
yarn-error.log*

# ── Node (Cloud Functions) ────────────────────────────────────────────
functions/node_modules/
functions/.env
functions/.runtimeconfig.json

# ── Archives & backups ────────────────────────────────────────────────
*.zip
*.tar.gz
chofly-*.zip
*-backup/
*_old/
